---
import BaseLayout from './BaseLayout.astro';
import { TRACKS, type TrackKey, SITE } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  track: TrackKey;
  tags: string[];
  readingTime: number;
  heroImage?: string;
}
const { title, description, pubDate, updatedDate, track, tags, readingTime, heroImage } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title={title} description={description} image={heroImage} article>
  <article class="post container">
    <header class="post-header">
      <a class="post-track" href={`/writing?track=${track}`}>{TRACKS[track].label}</a>
      <h1 class="post-title">{title}</h1>
      <p class="post-dek">{description}</p>
      <div class="post-meta">
        <span>{fmt(pubDate)}</span>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {fmt(updatedDate)}</span>
          </>
        )}
      </div>
    </header>

    {heroImage && <img class="post-hero" src={heroImage} alt="" />}

    <div class="post-content prose">
      <slot />
    </div>

    <footer class="post-footer">
      {tags.length > 0 && (
        <ul class="post-tags">
          {tags.map((t) => <li>{t}</li>)}
        </ul>
      )}
      <div class="post-byline">
        <img src="/images/avatar.webp" alt="" width="48" height="48" loading="lazy" decoding="async" />
        <div>
          <strong>{SITE.author}</strong>
          <span>{SITE.tagline}</span>
        </div>
      </div>
      <a class="post-back" href="/writing">← All writing</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--measure);
    padding-block: clamp(2.5rem, 7vw, 4.5rem) var(--space-xl);
  }
  .post-header {
    margin-bottom: var(--space-l);
  }
  .post-track {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
  }
  .post-title {
    font-family: var(--font-serif);
    font-weight: 650;
    font-size: var(--step-3);
    line-height: 1.18;
    margin-block: var(--space-xs) var(--space-s);
    letter-spacing: -0.01em;
  }
  .post-dek {
    font-size: var(--step-1);
    color: var(--text-muted);
  }
  .post-meta {
    margin-top: var(--space-s);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--text-faint);
  }
  .post-hero {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    margin-bottom: var(--space-l);
  }
  /* Give the article body comfortable rhythm via the shared .prose rules. */
  .post-content :global(h2) {
    margin-top: var(--space-l);
  }

  .post-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--border);
  }
  .post-tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: var(--space-l);
  }
  .post-tags li {
    font-family: var(--font-sans);
    font-size: 0.76rem;
    color: var(--text-muted);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: 0.12rem 0.6rem;
  }
  .post-byline {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    margin-bottom: var(--space-m);
  }
  .post-byline img {
    border-radius: 50%;
    object-fit: cover;
  }
  .post-byline div {
    display: flex;
    flex-direction: column;
    font-family: var(--font-sans);
  }
  .post-byline span {
    color: var(--text-muted);
    font-size: var(--step--1);
  }
  .post-back {
    font-family: var(--font-sans);
    font-size: var(--step--1);
  }
</style>

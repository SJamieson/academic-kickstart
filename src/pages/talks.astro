---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import PubLinks from '../components/PubLinks.astro';
import { TALK_CATEGORY_ORDER, TALK_CATEGORY_HEADINGS, formatMonthYear } from '../lib/format';

const talks = (await getCollection('talks')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const groups = TALK_CATEGORY_ORDER.map((category) => ({
  category,
  heading: TALK_CATEGORY_HEADINGS[category],
  items: talks.filter((t) => t.data.category === category),
})).filter((g) => g.items.length > 0);
---

<BaseLayout
  title="Talks"
  description="Invited talks, industry keynotes, and appearances by Stewart C. Jamieson on trustworthy AI, uncertainty quantification, and robotics."
>
  <PageHeader eyebrow="Talks" title="Talks & Appearances">
    <p>
      From research seminars to industry keynotes on making AI trustworthy — including Ai4, the CXO
      Forum, and award-winning pitches of Themis AI’s Capsa platform.
    </p>
  </PageHeader>

  <div class="container talks-page">
    {
      groups.map((group) => (
        <section class="talk-group">
          <h2 class="group-heading">{group.heading}</h2>
          <ul class="talk-list">
            {group.items.map((talk) => (
              <li class="talk-item">
                <div class="talk-date">{formatMonthYear(talk.data.date)}</div>
                <div class="talk-body">
                  <h3 class="talk-title">{talk.data.title}</h3>
                  <p class="talk-event">
                    {talk.data.role && <span class="talk-role">{talk.data.role}</span>}
                    {talk.data.role && ' · '}
                    {talk.data.event} — <span class="talk-loc">{talk.data.location}</span>
                  </p>
                  <PubLinks links={talk.data.links} />
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .talks-page {
    max-width: var(--measure-wide);
    padding-bottom: var(--space-xl);
  }
  .talk-group + .talk-group {
    margin-top: var(--space-l);
  }
  .group-heading {
    font-size: var(--step-1);
    padding-bottom: var(--space-2xs);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-s);
  }
  .talk-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
  .talk-item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--space-s);
  }
  .talk-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-faint);
    padding-top: 0.28rem;
  }
  .talk-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-start;
  }
  .talk-title {
    font-family: var(--font-serif);
    font-size: var(--step-0);
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: 0;
  }
  .talk-event {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--text-muted);
  }
  .talk-role {
    font-weight: 600;
    color: var(--accent);
  }
  @media (max-width: 34rem) {
    .talk-item {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }
    .talk-date {
      padding-top: 0;
    }
  }
</style>

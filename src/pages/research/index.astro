---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Authors from '../../components/Authors.astro';
import PubLinks from '../../components/PubLinks.astro';
import { PUB_TYPE_ORDER, PUB_TYPE_HEADINGS } from '../../lib/format';

const pubs = (await getCollection('publications')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const groups = PUB_TYPE_ORDER.map((type) => ({
  type,
  heading: PUB_TYPE_HEADINGS[type],
  items: pubs.filter((p) => p.data.type === type),
})).filter((g) => g.items.length > 0);

const count = pubs.length;
---

<BaseLayout
  title="Research"
  description="Peer-reviewed publications by Stewart C. Jamieson on risk-aware AI, multi-robot autonomy, and uncertainty quantification."
>
  <PageHeader eyebrow="Research" title="Research & Publications">
    <p>
      {count} publications spanning risk-aware machine learning, uncertainty quantification, and
      multi-robot autonomy — the research thread now applied to reliable AI at Themis AI.
    </p>
  </PageHeader>

  <div class="container pub-page">
    {
      groups.map((group) => (
        <section class="pub-group">
          <h2 class="group-heading">{group.heading}</h2>
          <ul class="pub-list">
            {group.items.map((pub) => (
              <li class="pub-item">
                <div class="pub-year">{pub.data.year}</div>
                <div class="pub-body">
                  <h3 class="pub-title">
                    <a href={`/publication/${pub.id}`}>{pub.data.title}</a>
                  </h3>
                  <Authors authors={pub.data.authors} />
                  <p class="pub-venue">{pub.data.venue}</p>
                  {pub.data.award && <span class="pub-award">★ {pub.data.award}</span>}
                  <PubLinks links={pub.data.links} />
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .pub-page {
    max-width: var(--measure-wide);
    padding-bottom: var(--space-xl);
  }
  .pub-group + .pub-group {
    margin-top: var(--space-l);
  }
  .group-heading {
    font-size: var(--step-1);
    padding-bottom: var(--space-2xs);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-s);
  }
  .pub-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
  .pub-item {
    display: grid;
    grid-template-columns: 3.4rem 1fr;
    gap: var(--space-s);
  }
  .pub-year {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-faint);
    padding-top: 0.28rem;
  }
  .pub-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-start;
  }
  .pub-title {
    font-family: var(--font-serif);
    font-size: var(--step-0);
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: 0;
  }
  .pub-title a {
    color: var(--text);
    text-decoration: none;
  }
  .pub-title a:hover {
    color: var(--accent);
  }
  .pub-venue {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-style: italic;
    color: var(--text-muted);
  }
  .pub-award {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: #9a6b00;
  }
  :global(html[data-theme='dark']) .pub-award {
    color: #e6b450;
  }
  @media (max-width: 30rem) {
    .pub-item {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }
    .pub-year {
      padding-top: 0;
    }
  }
</style>

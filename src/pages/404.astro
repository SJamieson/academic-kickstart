---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="Page not found.">
  <section class="container prose" style="padding-block: var(--space-2xl); text-align: center;">
    <p class="eyebrow">404</p>
    <h1>This page wandered off.</h1>
    <p class="text-muted">The page you’re looking for doesn’t exist or has moved.</p>
    <p style="margin-top: var(--space-m)"><a href="/">← Back home</a></p>
  </section>
</BaseLayout>

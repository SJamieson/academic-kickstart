---
// Interactive decision-region explorer for "Acting on Low Confidence".
// Heatmap of the reward-optimal action over (belief confidence p, false-negative
// penalty). Drag the crosshair anywhere to pick an operating point (belief × miss-
// cost); the two sliders (human cost, serve temperature) reshape the regions. Live
// net-value / handoff over a synthetic Beta(2,2) population, and per-action E[R].
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
---

<figure class="wide chart escalation" data-escalation>
  <div class="ctrls">
    <label>Human-review cost c<sub>h</sub> <output class="o-ch">4</output>
      <input class="s-ch" type="range" min="0" max="20" step="0.5" value="4" /></label>
    <label>Serve temperature τ <output class="o-tau">1.0</output>
      <input class="s-tau" type="range" min="0.2" max="3" step="0.05" value="1" /></label>
  </div>

  <div class="body">
    <div class="heat-wrap">
      <span class="y-label">← costlier to miss “harmful”</span>
      <canvas class="heat" role="img"
        aria-label="Decision-region map of the optimal action over belief confidence and miss-cost; drag to set an operating point"></canvas>
      <span class="x-label">belief that input is “harmful”, p →</span>
    </div>

    <div class="side">
      <div class="readouts">
        <div class="stat"><strong class="o-net">—</strong><small>net value / decision</small></div>
        <div class="stat"><strong class="o-hand">—</strong><small>human-handoff rate</small></div>
      </div>
      <p class="cross-read">at crosshair: p = <b class="o-p">—</b>, miss-cost = <b class="o-fn">—</b> <span class="drag-hint">— drag the map</span></p>
      <div class="legend">
        <span><i style="background:#0f766e"></i>serve “normal”</span>
        <span><i style="background:#d28a3c"></i>serve “harmful” (the safe call)</span>
        <span><i style="background:#8c8780"></i>escalate</span>
      </div>
      <div class="bars">
        <div class="bars-title">E[R] of each action here</div>
        <div class="bar"><span class="bar-k">normal</span><div class="bar-t"><i class="b-norm"></i></div><span class="bar-v v-norm">—</span></div>
        <div class="bar"><span class="bar-k">harmful</span><div class="bar-t"><i class="b-harm"></i></div><span class="bar-v v-harm">—</span></div>
        <div class="bar"><span class="bar-k">escalate</span><div class="bar-t"><i class="b-esc"></i></div><span class="bar-v v-esc">—</span></div>
      </div>
    </div>
  </div>
  {caption && <figcaption set:html={caption} />}
</figure>

<style>
  .escalation { margin-block: var(--space-l); padding: var(--space-m); border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); }
  .ctrls { display: flex; flex-wrap: wrap; gap: var(--space-m); margin-bottom: var(--space-s); }
  .ctrls label { font-family: var(--font-sans); font-size: var(--step--1); font-weight: 550; display: flex; flex-direction: column; gap: 0.25rem; min-width: 11rem; flex: 1; }
  .ctrls output { font-family: var(--font-mono); color: var(--accent); }
  .ctrls input { accent-color: var(--accent); width: 100%; }
  .body { display: flex; flex-wrap: wrap; gap: var(--space-m); align-items: stretch; }
  .heat-wrap { flex: 1 1 22rem; display: grid; grid-template-columns: auto 1fr; grid-template-rows: 1fr auto; gap: 0.3rem; align-items: center; }
  .heat { grid-column: 2; grid-row: 1; width: 100%; height: auto; aspect-ratio: 4 / 3; border-radius: var(--radius); cursor: crosshair; touch-action: none; }
  .y-label { grid-column: 1; grid-row: 1; writing-mode: vertical-rl; transform: rotate(180deg); font-family: var(--font-sans); font-size: 0.72rem; color: var(--text-muted); justify-self: center; }
  .x-label { grid-column: 2; grid-row: 2; text-align: center; font-family: var(--font-sans); font-size: 0.72rem; color: var(--text-muted); }
  .side { flex: 1 1 13rem; display: flex; flex-direction: column; gap: var(--space-s); font-family: var(--font-sans); }
  .readouts { display: flex; gap: var(--space-m); }
  .stat { display: flex; flex-direction: column; }
  .stat strong { font-size: var(--step-1); font-variant-numeric: tabular-nums; }
  .stat small { color: var(--text-muted); font-size: 0.72rem; }
  .cross-read { font-size: 0.76rem; color: var(--text-muted); }
  .cross-read b { font-family: var(--font-mono); color: var(--text); }
  .drag-hint { color: var(--text-faint); }
  .legend { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.76rem; color: var(--text-muted); }
  .legend i { display: inline-block; width: 0.7rem; height: 0.7rem; border-radius: 2px; margin-right: 0.4rem; vertical-align: -1px; }
  .bars-title { font-size: 0.72rem; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.3rem; }
  .bar { display: grid; grid-template-columns: 4rem 1fr 3rem; align-items: center; gap: 0.4rem; font-size: 0.78rem; }
  .bar-t { background: var(--bg-subtle); border-radius: 3px; height: 0.85rem; overflow: hidden; }
  .bar-t i { display: block; height: 100%; width: 0; }
  .b-norm { background: #0f766e; } .b-harm { background: #d28a3c; } .b-esc { background: #8c8780; }
  .bar-v { font-family: var(--font-mono); text-align: right; color: var(--text-muted); }
  figcaption { margin-top: 0.7rem; font-family: var(--font-sans); font-size: var(--step--1); color: var(--text-muted); text-align: center; }
</style>

<script>
  const C = { norm: '#0f766e', harm: '#d28a3c', esc: '#8c8780' };
  const REWARD_OK = 5, FP = -10, FN_TOP = -5, FN_BOT = -100;

  function mulberry32(seed: number) {
    return function () {
      seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }
  function makePopulation(n: number) {
    const r = mulberry32(7), pop: { p: number; harmful: boolean }[] = [];
    for (let i = 0; i < n; i++) {
      const a = r(), b = r(), c = r();
      const p = [a, b, c].sort((x, y) => x - y)[1]; // Beta(2,2) = median of 3 uniforms
      pop.push({ p, harmful: r() < p });
    }
    return pop;
  }
  const temper = (p: number, tau: number) => {
    const a = Math.pow(p, tau), b = Math.pow(1 - p, tau);
    return a / (a + b);
  };
  const eRewards = (ph: number, fn: number, ch: number) => [
    (1 - ph) * REWARD_OK + ph * fn, (1 - ph) * FP + ph * REWARD_OK, -ch,
  ];
  const argmax3 = (v: number[]) => (v[0] >= v[1] ? (v[0] >= v[2] ? 0 : 2) : v[1] >= v[2] ? 1 : 2);

  function init(root: HTMLElement) {
    const canvas = root.querySelector('.heat') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const pop = makePopulation(1500);
    const $ = (s: string) => root.querySelector(s) as HTMLElement;
    const sCh = $('.s-ch') as HTMLInputElement, sTau = $('.s-tau') as HTMLInputElement;

    let pCross = 0.35, fnCross = -50; // draggable operating point
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0, H = 0;

    function resize() {
      const rect = canvas.getBoundingClientRect();
      W = rect.width; H = rect.height;
      canvas.width = Math.round(W * dpr); canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      render();
    }

    function render() {
      const ch = +sCh.value, tau = +sTau.value;
      $('.o-ch').textContent = ch.toFixed(ch % 1 ? 1 : 0);
      $('.o-tau').textContent = tau.toFixed(2);

      const cell = 3;
      for (let px = 0; px < W; px += cell) {
        const ph = temper(px / W, tau);
        for (let py = 0; py < H; py += cell) {
          const pen = FN_TOP + (py / H) * (FN_BOT - FN_TOP);
          const a = argmax3(eRewards(ph, pen, ch));
          ctx.fillStyle = a === 0 ? C.norm : a === 1 ? C.harm : C.esc;
          ctx.globalAlpha = 0.85; ctx.fillRect(px, py, cell, cell);
        }
      }
      ctx.globalAlpha = 1;

      const cxp = pCross * W, cyp = ((FN_TOP - fnCross) / (FN_TOP - FN_BOT)) * H;
      ctx.strokeStyle = 'rgba(255,255,255,0.9)'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(cxp, 0); ctx.lineTo(cxp, H); ctx.moveTo(0, cyp); ctx.lineTo(W, cyp); ctx.stroke();
      ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(cxp, cyp, 4.5, 0, 7); ctx.fill();
      ctx.strokeStyle = '#111'; ctx.lineWidth = 1; ctx.stroke();

      let net = 0, hand = 0;
      for (const it of pop) {
        const ph = temper(it.p, tau);
        const a = argmax3(eRewards(ph, fnCross, ch));
        if (a === 2) { hand++; net += -ch; }
        else if (a === 0) net += it.harmful ? fnCross : REWARD_OK;
        else net += it.harmful ? REWARD_OK : FP;
      }
      $('.o-net').textContent = (net / pop.length).toFixed(2);
      $('.o-hand').textContent = ((hand / pop.length) * 100).toFixed(0) + '%';
      $('.o-p').textContent = pCross.toFixed(2);
      $('.o-fn').textContent = '−' + Math.abs(Math.round(fnCross));

      const er = eRewards(temper(pCross, tau), fnCross, ch);
      const span = REWARD_OK - fnCross;
      const bw = (v: number) => Math.max(0, Math.min(100, ((v - fnCross) / span) * 100));
      ($('.b-norm') as HTMLElement).style.width = bw(er[0]) + '%';
      ($('.b-harm') as HTMLElement).style.width = bw(er[1]) + '%';
      ($('.b-esc') as HTMLElement).style.width = bw(er[2]) + '%';
      $('.v-norm').textContent = er[0].toFixed(1);
      $('.v-harm').textContent = er[1].toFixed(1);
      $('.v-esc').textContent = er[2].toFixed(1);
    }

    function fromPointer(e: PointerEvent) {
      const rect = canvas.getBoundingClientRect();
      pCross = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      const fy = Math.max(0, Math.min(1, (e.clientY - rect.top) / rect.height));
      fnCross = FN_TOP + fy * (FN_BOT - FN_TOP);
      render();
    }
    let dragging = false;
    canvas.addEventListener('pointerdown', (e) => { dragging = true; canvas.setPointerCapture(e.pointerId); fromPointer(e); });
    canvas.addEventListener('pointermove', (e) => { if (dragging) fromPointer(e); });
    canvas.addEventListener('pointerup', () => (dragging = false));
    [sCh, sTau].forEach((s) => s.addEventListener('input', render));
    let rt: number;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = window.setTimeout(resize, 150); });
    resize();
  }

  document.querySelectorAll<HTMLElement>('[data-escalation]').forEach(init);
</script>

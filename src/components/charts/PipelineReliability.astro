---
// "Building Reliable Systems…" — a confident 3-stage pipeline vs. one whose stages
// flag low confidence so the system can escalate. One slider (input difficulty)
// sweeps the regime: the uncertainty-aware system is never worse, and pulls ahead
// as inputs get harder. Deterministic synthetic model with correlated errors.
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
---

<figure class="wide chart pipeline" data-pipeline>
  <div class="systems">
    <div class="sys sys-bare"><strong class="o-conf">—</strong><span>Confident system<br/><small>serves every answer</small></span></div>
    <div class="sys sys-aware"><strong class="o-aware">—</strong><span>Uncertainty-aware system<br/><small>escalates when unsure</small></span></div>
    <div class="gain"><strong class="o-gain">—</strong><span>more reliable<br/><small class="o-esc">—</small></span></div>
  </div>

  <canvas class="plot" role="img" aria-label="End-to-end reliability vs input difficulty for a confident system and an uncertainty-aware system"></canvas>

  <label class="diff">Input difficulty&nbsp; <span class="d-easy">easy</span>
    <input class="s-diff" type="range" min="0" max="60" step="1" value="24" />
    <span class="d-hard">hard</span></label>
  {caption && <figcaption set:html={caption} />}
</figure>

<style>
  .pipeline { margin-block: var(--space-l); padding: var(--space-m); border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--surface); font-family: var(--font-sans); }
  .systems { display: flex; flex-wrap: wrap; gap: var(--space-m); margin-bottom: var(--space-s); }
  .sys { flex: 1 1 9rem; display: flex; align-items: baseline; gap: 0.5rem; }
  .sys strong { font-size: var(--step-2); font-variant-numeric: tabular-nums; line-height: 1; }
  .sys span { font-size: 0.78rem; color: var(--text-muted); }
  .sys small { color: var(--text-faint); }
  .sys-bare strong { color: #8c8780; }
  .sys-aware strong { color: var(--accent); }
  .gain { flex: 1 1 7rem; display: flex; align-items: baseline; gap: 0.5rem; padding-left: var(--space-s); border-left: 1px solid var(--border); }
  .gain strong { font-size: var(--step-2); font-variant-numeric: tabular-nums; color: var(--accent); }
  .gain span { font-size: 0.78rem; color: var(--text-muted); }
  .plot { width: 100%; height: auto; aspect-ratio: 5 / 2; }
  .diff { display: flex; align-items: center; gap: 0.6rem; font-size: var(--step--1); font-weight: 550; margin-top: var(--space-xs); }
  .diff input { accent-color: var(--accent); flex: 1; }
  .d-easy, .d-hard { color: var(--text-muted); font-weight: 500; }
  figcaption { margin-top: 0.7rem; font-size: var(--step--1); color: var(--text-muted); text-align: center; }
</style>

<script>
  const N = 4000, ACC = [0.95, 0.94, 0.96], BETA = 0.5, SHIFT = 0.18, T = 0.4, STEPS = 60;
  const TEAL = '#0f766e', GREY = '#8c8780';

  function mulberry32(seed: number) {
    return function () {
      seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }
  const rnd = mulberry32(11);
  const D: number[] = [], U: number[][] = [[], [], []];
  for (let i = 0; i < N; i++) { D.push(rnd()); for (let k = 0; k < 3; k++) U[k].push(rnd()); }
  const clamp = (x: number) => Math.max(0.02, Math.min(0.999, x));

  // reliability of both systems at difficulty g in [0,1]
  function reliab(g: number) {
    let conf = 0, aware = 0, esc = 0;
    for (let i = 0; i < N; i++) {
      const d = D[i];
      let cc = 1, allOk = true;
      for (let k = 0; k < 3; k++) {
        const q = clamp(ACC[k] - SHIFT * g - BETA * (d - 0.5));
        cc *= q;                          // composed chain-confidence
        if (U[k][i] >= q) allOk = false;  // this stage served a wrong answer
      }
      if (allOk) conf++;
      if (cc < T) { esc++; aware++; }      // genuinely uncertain → escalate (handled)
      else if (allOk) aware++;             // confident enough → serve
    }
    return { conf: conf / N, aware: aware / N, esc: esc / N };
  }

  // precompute curves once
  const curve = Array.from({ length: STEPS + 1 }, (_, i) => reliab(i / STEPS));

  function init(root: HTMLElement) {
    const $ = (s: string) => root.querySelector(s) as HTMLElement;
    const canvas = root.querySelector('.plot') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const sDiff = $('.s-diff') as HTMLInputElement;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0, H = 0;
    const ML = 38, MR = 10, MT = 12, MB = 22;

    function resize() {
      const rect = canvas.getBoundingClientRect();
      W = rect.width; H = rect.height;
      canvas.width = Math.round(W * dpr); canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      render();
    }
    const X = (g: number) => ML + g * (W - ML - MR);
    const Y = (r: number) => MT + (1 - r) * (H - MT - MB);

    function line(sel: (c: { conf: number; aware: number; esc: number }) => number) {
      ctx.beginPath();
      curve.forEach((c, i) => { const x = X(i / STEPS), y = Y(sel(c)); i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); });
    }

    function render() {
      const idx = +sDiff.value, cur = curve[idx];
      ctx.clearRect(0, 0, W, H);
      // y gridlines
      ctx.font = '10px ui-sans-serif, sans-serif'; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
      for (let r = 0; r <= 1; r += 0.25) {
        const y = Y(r);
        ctx.strokeStyle = 'rgba(128,128,128,0.18)'; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(ML, y); ctx.lineTo(W - MR, y); ctx.stroke();
        ctx.fillStyle = 'rgba(128,128,128,0.8)'; ctx.fillText((r * 100).toFixed(0) + '%', ML - 5, y);
      }
      // shaded gap (the uncertainty dividend)
      line((c) => c.aware);
      for (let i = STEPS; i >= 0; i--) ctx.lineTo(X(i / STEPS), Y(curve[i].conf));
      ctx.closePath(); ctx.fillStyle = 'rgba(15,118,110,0.12)'; ctx.fill();
      // lines
      line((c) => c.conf); ctx.strokeStyle = GREY; ctx.lineWidth = 2; ctx.stroke();
      line((c) => c.aware); ctx.strokeStyle = TEAL; ctx.lineWidth = 2.5; ctx.stroke();
      // marker
      const mx = X(idx / STEPS);
      ctx.strokeStyle = 'rgba(128,128,128,0.5)'; ctx.lineWidth = 1; ctx.setLineDash([3, 3]);
      ctx.beginPath(); ctx.moveTo(mx, MT); ctx.lineTo(mx, H - MB); ctx.stroke(); ctx.setLineDash([]);
      for (const [r, col] of [[cur.conf, GREY], [cur.aware, TEAL]] as [number, string][]) {
        ctx.fillStyle = col; ctx.beginPath(); ctx.arc(mx, Y(r), 4, 0, 7); ctx.fill();
        ctx.strokeStyle = 'var(--surface)'; ctx.lineWidth = 1.5; ctx.strokeStyle = '#fff'; ctx.stroke();
      }

      $('.o-conf').textContent = (cur.conf * 100).toFixed(0) + '%';
      $('.o-aware').textContent = (cur.aware * 100).toFixed(0) + '%';
      $('.o-gain').textContent = '+' + ((cur.aware - cur.conf) * 100).toFixed(0) + 'pts';
      $('.o-esc').textContent = 'hands ' + (cur.esc * 100).toFixed(0) + '% to review';
    }

    sDiff.addEventListener('input', render);
    let rt: number;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = window.setTimeout(resize, 150); });
    resize();
  }

  document.querySelectorAll<HTMLElement>('[data-pipeline]').forEach(init);
</script>

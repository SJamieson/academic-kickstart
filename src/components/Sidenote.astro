---
// Margin sidenote. Sits in the right margin on wide screens; collapses to an
// inline note block on narrower viewports. Pass an optional number `n`.
interface Props {
  n?: number | string;
}
const { n } = Astro.props;
---

<span class="sidenote-wrap">
  {n != null && <sup class="sidenote-ref">{n}</sup>}
  <aside class="sidenote">
    {n != null && <sup class="sidenote-num">{n}</sup>}
    <slot />
  </aside>
</span>

<style>
  .sidenote-wrap {
    /* keeps the marker tight to surrounding text */
  }
  .sidenote-ref {
    color: var(--accent);
    font-family: var(--font-sans);
    font-weight: 600;
    cursor: default;
  }
  .sidenote {
    display: block;
    margin-block: var(--space-xs);
    padding-inline-start: 0.85rem;
    border-inline-start: 2px solid var(--border-strong);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    line-height: 1.5;
    color: var(--text-muted);
  }
  .sidenote-num {
    color: var(--accent);
    font-weight: 600;
    margin-inline-end: 0.3em;
  }
  /* On wide screens, float the note into the right margin alongside the text. */
  @media (min-width: 82rem) {
    .sidenote {
      float: right;
      clear: right;
      width: 13.5rem;
      margin-inline-end: -15.5rem;
      margin-block: 0.25rem;
      padding-inline-start: 0;
      border-inline-start: none;
    }
    .sidenote-ref {
      display: none;
    }
  }
</style>

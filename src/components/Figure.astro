---
// Captioned figure that can break wider than the reading column.
// Use with an image `src`, or wrap arbitrary content (e.g. a chart) via the slot.
interface Props {
  src?: string;
  alt?: string;
  caption?: string;
  /** Break out of the reading column. */
  size?: 'normal' | 'wide' | 'full';
}
const { src, alt = '', caption, size = 'normal' } = Astro.props;
const sizeClass = size === 'wide' ? 'wide' : size === 'full' ? 'full' : '';
---

<figure class:list={['figure', sizeClass]}>
  {src ? <img src={src} alt={alt} loading="lazy" decoding="async" /> : <slot />}
  {caption && <figcaption set:html={caption} />}
</figure>

<style>
  .figure {
    margin-block: var(--space-l);
  }
  .figure img {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .figure figcaption {
    margin-top: 0.6rem;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    line-height: 1.5;
    color: var(--text-muted);
    text-align: center;
  }
  .figure.wide figcaption,
  .figure.full figcaption {
    max-width: var(--measure);
    margin-inline: auto;
  }
</style>
